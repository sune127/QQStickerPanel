<Window x:Class="QQStickerPanel.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="设置"
        Width="440"
        Height="660"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize">
    <Border Margin="12"
            Padding="16"
            Background="{StaticResource PanelBackgroundBrush}"
            CornerRadius="{StaticResource WindowCornerRadius}"
            Effect="{StaticResource PanelShadow}">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <StackPanel Grid.Row="0" Margin="0,0,0,12">
                <TextBlock Text="设置"
                           FontSize="18"
                           FontWeight="SemiBold" />
                <TextBlock Style="{StaticResource CaptionTextStyle}"
                           Margin="0,4,0,0"
                           Text="配置表情目录、QQ 绑定和吸附行为" />
            </StackPanel>

            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                <StackPanel>
                    <Border Padding="12"
                            Background="{StaticResource CardBackgroundBrush}"
                            BorderBrush="{StaticResource BorderSoftBrush}"
                            BorderThickness="1"
                            CornerRadius="{StaticResource CardCornerRadius}"
                            Effect="{StaticResource CardShadow}">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="82" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <TextBlock Grid.Row="0"
                                       Grid.ColumnSpan="2"
                                       Style="{StaticResource SectionTitleTextStyle}"
                                       Text="表情库" />

                            <TextBlock Grid.Row="1" Grid.Column="0" Style="{StaticResource FieldLabelTextStyle}" Text="表情目录" />
                            <TextBox x:Name="StickerRootBox" Grid.Row="1" Grid.Column="1" Margin="0,0,0,8" />

                            <TextBlock Grid.Row="2" Grid.Column="0" Style="{StaticResource FieldLabelTextStyle}" Text="扩展名" />
                            <TextBox x:Name="ExtensionsBox" Grid.Row="2" Grid.Column="1" Margin="0,0,0,8" />

                            <TextBlock Grid.Row="3" Grid.Column="0" Style="{StaticResource FieldLabelTextStyle}" Text="最近数量" />
                            <TextBox x:Name="RecentLimitBox" Grid.Row="3" Grid.Column="1" />
                        </Grid>
                    </Border>

                    <Border Margin="0,10,0,0"
                            Padding="12"
                            Background="{StaticResource CardBackgroundBrush}"
                            BorderBrush="{StaticResource BorderSoftBrush}"
                            BorderThickness="1"
                            CornerRadius="{StaticResource CardCornerRadius}">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="82" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <TextBlock Grid.Row="0"
                                       Grid.ColumnSpan="2"
                                       Style="{StaticResource SectionTitleTextStyle}"
                                       Text="QQ 与吸附" />

                            <TextBlock Grid.Row="1" Grid.Column="0" Style="{StaticResource FieldLabelTextStyle}" Text="QQ 进程" />
                            <TextBox x:Name="ProcessNamesBox" Grid.Row="1" Grid.Column="1" Margin="0,0,0,8" />

                            <TextBlock Grid.Row="2" Grid.Column="0" Style="{StaticResource FieldLabelTextStyle}" Text="吸附位置" />
                            <ComboBox x:Name="DockSideBox" Grid.Row="2" Grid.Column="1" Margin="0,0,0,8" SelectedValuePath="Tag">
                                <ComboBoxItem Content="QQ 右侧" Tag="Right" />
                                <ComboBoxItem Content="QQ 内右侧" Tag="InnerRight" />
                                <ComboBoxItem Content="QQ 左侧" Tag="Left" />
                                <ComboBoxItem Content="QQ 内左侧" Tag="InnerLeft" />
                                <ComboBoxItem Content="QQ 上方" Tag="Top" />
                                <ComboBoxItem Content="QQ 下方" Tag="Bottom" />
                            </ComboBox>

                            <TextBlock Grid.Row="3" Grid.Column="0" Style="{StaticResource FieldLabelTextStyle}" Text="面板宽度" />
                            <TextBox x:Name="DockWidthBox" Grid.Row="3" Grid.Column="1" Margin="0,0,0,8" />

                            <TextBlock Grid.Row="4" Grid.Column="0" Style="{StaticResource FieldLabelTextStyle}" Text="吸附间距" />
                            <TextBox x:Name="DockGapBox" Grid.Row="4" Grid.Column="1" Margin="0,0,0,8" />

                            <TextBlock Grid.Row="5" Grid.Column="0" Style="{StaticResource FieldLabelTextStyle}" Text="跟随间隔" />
                            <TextBox x:Name="FollowIntervalBox"
                                     Grid.Row="5"
                                     Grid.Column="1"
                                     Margin="0,0,0,8"
                                     ToolTip="毫秒，建议 16-100" />

                            <TextBlock Grid.Row="6" Grid.Column="0" Style="{StaticResource FieldLabelTextStyle}" Text="双击发送" />
                            <CheckBox x:Name="SendAfterPasteBox"
                                      Grid.Row="6"
                                      Grid.Column="1"
                                      Margin="0,0,0,8"
                                      Content="双击粘贴到 QQ 后自动发送" />

                            <TextBlock Grid.Row="7" Grid.Column="0" Style="{StaticResource FieldLabelTextStyle}" Text="发送快捷键" />
                            <ComboBox x:Name="SendShortcutBox" Grid.Row="7" Grid.Column="1" SelectedValuePath="Tag">
                                <ComboBoxItem Content="Enter" Tag="Enter" />
                                <ComboBoxItem Content="Ctrl+Enter" Tag="CtrlEnter" />
                            </ComboBox>

                            <TextBlock Grid.Row="8" Grid.Column="0" Style="{StaticResource FieldLabelTextStyle}" Text="自动隐藏" />
                            <StackPanel Grid.Row="8" Grid.Column="1">
                                <CheckBox x:Name="HideWhenQQNotRunningBox"
                                          Margin="0,0,0,6"
                                          Content="QQ 未启动或无聊天窗口时隐藏到托盘" />
                                <CheckBox x:Name="HideWhenQQNotForegroundBox"
                                          Margin="0,0,0,6"
                                          Content="QQ 不在前台时隐藏到托盘" />
                                <CheckBox x:Name="ShowWhenQQForegroundBox"
                                          Margin="0,0,0,8"
                                          Content="QQ 回到前台时自动显示" />
                            </StackPanel>

                            <TextBlock Grid.Row="9" Grid.Column="0" Style="{StaticResource FieldLabelTextStyle}" Text="匹配分" />
                            <TextBox x:Name="WindowMatchScoreBox"
                                     Grid.Row="9"
                                     Grid.Column="1"
                                     Margin="0,0,0,8"
                                     ToolTip="聊天窗口匹配最低分，默认 70" />

                            <TextBlock Grid.Row="10" Grid.Column="0" Style="{StaticResource FieldLabelTextStyle}" Text="诊断" />
                            <CheckBox x:Name="MatchDiagnosticsBox"
                                      Grid.Row="10"
                                      Grid.Column="1"
                                      Content="记录 QQ 窗口匹配诊断日志" />
                        </Grid>
                    </Border>

                    <Border Margin="0,10,0,0"
                            Padding="12"
                            Background="{StaticResource CardBackgroundBrush}"
                            BorderBrush="{StaticResource BorderSoftBrush}"
                            BorderThickness="1"
                            CornerRadius="{StaticResource CardCornerRadius}">
                        <StackPanel>
                            <TextBlock Style="{StaticResource SectionTitleTextStyle}" Text="启动与显示" />
                            <CheckBox x:Name="FreeDockBox"
                                      Margin="0,0,0,8"
                                      Content="启动时保持自由停靠" />
                            <CheckBox x:Name="TopmostBox"
                                      Margin="0,0,0,8"
                                      Content="QQ 在前台时同步前置面板" />
                            <CheckBox x:Name="StartupBox" Content="开机启动" />
                        </StackPanel>
                    </Border>
                </StackPanel>
            </ScrollViewer>

            <StackPanel Grid.Row="2"
                        Margin="0,12,0,0"
                        Orientation="Horizontal"
                        HorizontalAlignment="Right">
                <Button Width="76"
                        Margin="0,0,8,0"
                        Content="保存"
                        IsDefault="True"
                        Style="{StaticResource PrimaryButtonStyle}"
                        Click="OnSaveClick" />
                <Button Width="76" Content="取消" IsCancel="True" />
            </StackPanel>
        </Grid>
    </Border>
</Window>
