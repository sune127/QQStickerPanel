<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <FontFamily x:Key="AppFontFamily">Segoe UI, Microsoft YaHei UI</FontFamily>

    <Color x:Key="AppBackgroundColor">#FFF4F6FB</Color>
    <Color x:Key="PanelBackgroundColor">#FFF9FAFD</Color>
    <Color x:Key="CardBackgroundColor">#FFFFFFFF</Color>
    <Color x:Key="CardMutedBackgroundColor">#FFF3F6FB</Color>
    <Color x:Key="ControlBackgroundColor">#FFFFFFFF</Color>
    <Color x:Key="ControlHoverBackgroundColor">#FFF4F8FF</Color>
    <Color x:Key="ControlPressedBackgroundColor">#FFE7F0FF</Color>
    <Color x:Key="AccentColor">#FF2563EB</Color>
    <Color x:Key="AccentHoverColor">#FF1D4ED8</Color>
    <Color x:Key="AccentSoftColor">#FFEAF2FF</Color>
    <Color x:Key="AccentBorderColor">#FF93B4FF</Color>
    <Color x:Key="TextPrimaryColor">#FF172033</Color>
    <Color x:Key="TextSecondaryColor">#FF667085</Color>
    <Color x:Key="TextMutedColor">#FF98A2B3</Color>
    <Color x:Key="BorderSoftColor">#FFE3E8F0</Color>
    <Color x:Key="BorderStrongColor">#FFC9D4E5</Color>
    <Color x:Key="WarningColor">#FFF59E0B</Color>
    <Color x:Key="OverlayAccentColor">#CC2563EB</Color>

    <SolidColorBrush x:Key="AppBackgroundBrush" Color="{StaticResource AppBackgroundColor}" />
    <SolidColorBrush x:Key="PanelBackgroundBrush" Color="{StaticResource PanelBackgroundColor}" />
    <SolidColorBrush x:Key="CardBackgroundBrush" Color="{StaticResource CardBackgroundColor}" />
    <SolidColorBrush x:Key="CardMutedBackgroundBrush" Color="{StaticResource CardMutedBackgroundColor}" />
    <SolidColorBrush x:Key="ControlBackgroundBrush" Color="{StaticResource ControlBackgroundColor}" />
    <SolidColorBrush x:Key="ControlHoverBackgroundBrush" Color="{StaticResource ControlHoverBackgroundColor}" />
    <SolidColorBrush x:Key="ControlPressedBackgroundBrush" Color="{StaticResource ControlPressedBackgroundColor}" />
    <SolidColorBrush x:Key="AccentBrush" Color="{StaticResource AccentColor}" />
    <SolidColorBrush x:Key="AccentHoverBrush" Color="{StaticResource AccentHoverColor}" />
    <SolidColorBrush x:Key="AccentSoftBrush" Color="{StaticResource AccentSoftColor}" />
    <SolidColorBrush x:Key="AccentBorderBrush" Color="{StaticResource AccentBorderColor}" />
    <SolidColorBrush x:Key="TextPrimaryBrush" Color="{StaticResource TextPrimaryColor}" />
    <SolidColorBrush x:Key="TextSecondaryBrush" Color="{StaticResource TextSecondaryColor}" />
    <SolidColorBrush x:Key="TextMutedBrush" Color="{StaticResource TextMutedColor}" />
    <SolidColorBrush x:Key="BorderSoftBrush" Color="{StaticResource BorderSoftColor}" />
    <SolidColorBrush x:Key="BorderStrongBrush" Color="{StaticResource BorderStrongColor}" />
    <SolidColorBrush x:Key="WarningBrush" Color="{StaticResource WarningColor}" />
    <SolidColorBrush x:Key="OverlayAccentBrush" Color="{StaticResource OverlayAccentColor}" />
    <SolidColorBrush x:Key="WhiteBrush" Color="#FFFFFFFF" />

    <CornerRadius x:Key="WindowCornerRadius">18</CornerRadius>
    <CornerRadius x:Key="CardCornerRadius">16</CornerRadius>
    <CornerRadius x:Key="ControlCornerRadius">10</CornerRadius>
    <CornerRadius x:Key="ChipCornerRadius">14</CornerRadius>
    <CornerRadius x:Key="SmallCornerRadius">8</CornerRadius>

    <Thickness x:Key="WindowPadding">12</Thickness>
    <Thickness x:Key="CardPadding">12</Thickness>
    <Thickness x:Key="ControlPadding">10,6</Thickness>

    <DropShadowEffect x:Key="PanelShadow"
                      BlurRadius="18"
                      Direction="270"
                      Opacity="0.16"
                      ShadowDepth="4"
                      Color="#FF536179" />
    <DropShadowEffect x:Key="CardShadow"
                      BlurRadius="10"
                      Direction="270"
                      Opacity="0.09"
                      ShadowDepth="2"
                      Color="#FF536179" />
</ResourceDictionary>
