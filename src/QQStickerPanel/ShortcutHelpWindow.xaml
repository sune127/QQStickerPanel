<Window x:Class="QQStickerPanel.ShortcutHelpWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="快捷键说明"
        Width="360"
        Height="440"
        MinWidth="320"
        MinHeight="360"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResize">
    <Border Margin="12"
            Padding="16"
            Background="{StaticResource PanelBackgroundBrush}"
            BorderBrush="{StaticResource BorderSoftBrush}"
            BorderThickness="1"
            CornerRadius="{StaticResource CardCornerRadius}">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <StackPanel>
                <TextBlock Style="{StaticResource SectionTitleTextStyle}" Text="快捷键说明" />
                <TextBlock Style="{StaticResource CaptionTextStyle}" Text="常用操作仍保留鼠标和右键菜单入口。" />
            </StackPanel>

            <ScrollViewer Grid.Row="1" Margin="0,12,0,12" VerticalScrollBarVisibility="Auto">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="120" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Grid.Column="0" Margin="0,0,10,8" FontWeight="SemiBold" Text="Ctrl+Alt+Q" />
                    <TextBlock Grid.Row="0" Grid.Column="1" Margin="0,0,0,8" Text="显示/隐藏面板" />
                    <TextBlock Grid.Row="1" Grid.Column="0" Margin="0,0,10,8" FontWeight="SemiBold" Text="F1" />
                    <TextBlock Grid.Row="1" Grid.Column="1" Margin="0,0,0,8" Text="打开快捷键说明" />
                    <TextBlock Grid.Row="2" Grid.Column="0" Margin="0,0,10,8" FontWeight="SemiBold" Text="Ctrl+V" />
                    <TextBlock Grid.Row="2" Grid.Column="1" Margin="0,0,0,8" Text="从剪贴板导入" />
                    <TextBlock Grid.Row="3" Grid.Column="0" Margin="0,0,10,8" FontWeight="SemiBold" Text="Ctrl+A" />
                    <TextBlock Grid.Row="3" Grid.Column="1" Margin="0,0,0,8" Text="全选当前列表" />
                    <TextBlock Grid.Row="4" Grid.Column="0" Margin="0,0,10,8" FontWeight="SemiBold" Text="Ctrl+I" />
                    <TextBlock Grid.Row="4" Grid.Column="1" Margin="0,0,0,8" Text="反选当前列表" />
                    <TextBlock Grid.Row="5" Grid.Column="0" Margin="0,0,10,8" FontWeight="SemiBold" Text="Esc" />
                    <TextBlock Grid.Row="5" Grid.Column="1" Margin="0,0,0,8" Text="取消全部选择" />
                    <TextBlock Grid.Row="6" Grid.Column="0" Margin="0,0,10,8" FontWeight="SemiBold" Text="Ctrl+C" />
                    <TextBlock Grid.Row="6" Grid.Column="1" Margin="0,0,0,8" Text="复制已选表情" />
                    <TextBlock Grid.Row="7" Grid.Column="0" Margin="0,0,10,8" FontWeight="SemiBold" Text="Ctrl+F" />
                    <TextBlock Grid.Row="7" Grid.Column="1" Margin="0,0,0,8" Text="收藏/取消收藏选中表情" />
                    <TextBlock Grid.Row="8" Grid.Column="0" Margin="0,0,10,8" FontWeight="SemiBold" Text="Ctrl+O" />
                    <TextBlock Grid.Row="8" Grid.Column="1" Margin="0,0,0,8" Text="打开当前分类目录" />
                    <TextBlock Grid.Row="9" Grid.Column="0" Margin="0,0,10,8" FontWeight="SemiBold" Text="Ctrl+Tab" />
                    <TextBlock Grid.Row="9" Grid.Column="1" Margin="0,0,0,8" Text="切换到下一个分类" />
                    <TextBlock Grid.Row="10" Grid.Column="0" Margin="0,0,10,8" FontWeight="SemiBold" Text="Ctrl+Shift+Tab" />
                    <TextBlock Grid.Row="10" Grid.Column="1" Margin="0,0,0,8" Text="切换到上一个分类" />
                    <TextBlock Grid.Row="11" Grid.Column="0" Margin="0,0,10,8" FontWeight="SemiBold" Text="Ctrl +/-" />
                    <TextBlock Grid.Row="11" Grid.Column="1" Margin="0,0,0,8" Text="调整面板宽度" />
                    <TextBlock Grid.Row="12" Grid.Column="0" Margin="0,0,10,8" FontWeight="SemiBold" Text="F2" />
                    <TextBlock Grid.Row="12" Grid.Column="1" Margin="0,0,0,8" Text="重命名表情" />
                    <TextBlock Grid.Row="13" Grid.Column="0" Margin="0,0,10,0" FontWeight="SemiBold" Text="Delete" />
                    <TextBlock Grid.Row="13" Grid.Column="1" Text="移入回收站" />
                </Grid>
            </ScrollViewer>

            <Button Grid.Row="2"
                    Width="76"
                    HorizontalAlignment="Right"
                    Content="关闭"
                    IsCancel="True" />
        </Grid>
    </Border>
</Window>
