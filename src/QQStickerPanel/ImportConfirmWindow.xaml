<Window x:Class="QQStickerPanel.ImportConfirmWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="确认导入"
        Width="440"
        Height="500"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize">
    <Border Margin="12"
            Padding="16"
            Background="{StaticResource PanelBackgroundBrush}"
            CornerRadius="{StaticResource WindowCornerRadius}"
            Effect="{StaticResource PanelShadow}">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <StackPanel Grid.Row="0" Margin="0,0,0,12">
                <TextBlock Text="确认导入"
                           FontSize="18"
                           FontWeight="SemiBold" />
                <TextBlock x:Name="SummaryText"
                           Style="{StaticResource CaptionTextStyle}"
                           Margin="0,4,0,0"
                           TextWrapping="Wrap" />
            </StackPanel>

            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                <StackPanel>
                    <Border Padding="12"
                            Background="{StaticResource CardBackgroundBrush}"
                            BorderBrush="{StaticResource BorderSoftBrush}"
                            BorderThickness="1"
                            CornerRadius="{StaticResource CardCornerRadius}"
                            Effect="{StaticResource CardShadow}">
                        <StackPanel>
                            <TextBlock Style="{StaticResource SectionTitleTextStyle}" Text="待导入文件" />
                            <ListBox x:Name="FileListBox" Height="96" />
                        </StackPanel>
                    </Border>

                    <Border Margin="0,10,0,0"
                            Padding="12"
                            Background="{StaticResource CardBackgroundBrush}"
                            BorderBrush="{StaticResource BorderSoftBrush}"
                            BorderThickness="1"
                            CornerRadius="{StaticResource CardCornerRadius}">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="82" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <TextBlock Grid.Row="0"
                                       Grid.ColumnSpan="2"
                                       Style="{StaticResource SectionTitleTextStyle}"
                                       Text="导入选项" />

                            <TextBlock Grid.Row="1" Grid.Column="0" Style="{StaticResource FieldLabelTextStyle}" Text="保存分类" />
                            <ComboBox x:Name="CategoryBox"
                                      Grid.Row="1"
                                      Grid.Column="1"
                                      Margin="0,0,0,8"
                                      DisplayMemberPath="DisplayName" />

                            <TextBlock Grid.Row="2" Grid.Column="0" Style="{StaticResource FieldLabelTextStyle}" Text="新建分类" />
                            <TextBox x:Name="NewCategoryBox"
                                     Grid.Row="2"
                                     Grid.Column="1"
                                     Margin="0,0,0,8"
                                     ToolTip="留空则保存到上方选择的分类；可输入一级或多级分类名" />

                            <TextBlock Grid.Row="3" Grid.Column="0" Style="{StaticResource FieldLabelTextStyle}" Text="标签" />
                            <TextBox x:Name="TagsBox"
                                     Grid.Row="3"
                                     Grid.Column="1"
                                     Margin="0,0,0,10"
                                     ToolTip="用空格、逗号或 # 分隔多个标签" />

                            <CheckBox x:Name="FavoriteBox"
                                      Grid.Row="4"
                                      Grid.Column="1"
                                      Margin="0,0,0,8"
                                      Content="导入后收藏" />

                            <CheckBox x:Name="DeduplicateBox"
                                      Grid.Row="5"
                                      Grid.Column="1"
                                      Content="按内容去重，跳过已存在图片"
                                      IsChecked="True" />
                        </Grid>
                    </Border>

                    <Border Margin="0,10,0,0"
                            Padding="10"
                            Background="{StaticResource AccentSoftBrush}"
                            BorderBrush="{StaticResource AccentBorderBrush}"
                            BorderThickness="1"
                            CornerRadius="{StaticResource ControlCornerRadius}">
                        <TextBlock x:Name="HintText"
                                   Foreground="{StaticResource AccentBrush}"
                                   TextWrapping="Wrap" />
                    </Border>
                </StackPanel>
            </ScrollViewer>

            <StackPanel Grid.Row="2"
                        Margin="0,12,0,0"
                        Orientation="Horizontal"
                        HorizontalAlignment="Right">
                <Button Width="76"
                        Margin="0,0,8,0"
                        Content="导入"
                        IsDefault="True"
                        Style="{StaticResource PrimaryButtonStyle}"
                        Click="OnImportClick" />
                <Button Width="76" Content="取消" IsCancel="True" />
            </StackPanel>
        </Grid>
    </Border>
</Window>
